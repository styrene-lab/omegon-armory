---
import type { ArmoryItem } from "../types";

type Props = {
  items: ArmoryItem[];
  title?: string;
  intro?: string;
  activeKind?: string;
};

const { items, title = "Packages", intro, activeKind = "all" } = Astro.props;
const categories = Array.from(new Set(items.map((item) => item.category).filter(Boolean))).sort();
const licenses = Array.from(new Set(items.map((item) => item.license).filter(Boolean))).sort();
const publishers = Array.from(new Set(items.map((item) => item.publisher).filter(Boolean))).sort();
const kinds = ["all", "extension", "skill", "persona", "tone", "agent"];

const countBy = (field: keyof ArmoryItem, value: string) =>
  items.filter((item) => item[field] === value).length;

const hasDistinctRepository = (item: ArmoryItem) =>
  item.repositoryUrl && item.repositoryUrl !== item.sourceUrl;
---

<section class="catalog-shell" data-catalog>
  <div class="section-heading">
    <div>
      <p class="eyebrow">Catalog</p>
      <h1>{title}</h1>
      {intro && <p>{intro}</p>}
    </div>
    <div class="count" data-count>{items.length} packages</div>
  </div>

  <div class="catalog-layout">
    <aside class="filter-panel" aria-label="Package filters">
      <label class="search-control">
        <span>Search packages</span>
        <input data-search type="search" placeholder="Search by name, kind, ref, capability" autocomplete="off" />
      </label>

      <fieldset>
        <legend>Kind</legend>
        {kinds.map((kind) => (
          <label class="check-row">
            <input data-kind type="checkbox" value={kind} checked={kind === activeKind || (activeKind === "all" && kind === "all")} />
            <span>{kind}</span>
            <small>{kind === "all" ? items.length : countBy("kind", kind)}</small>
          </label>
        ))}
      </fieldset>

      <fieldset>
        <legend>Distribution</legend>
        <label class="check-row">
          <input data-distribution type="checkbox" value="oci" />
          <span>OCI artifact</span>
          <small>{items.filter((item) => item.distribution === "oci").length}</small>
        </label>
        <label class="check-row">
          <input data-distribution type="checkbox" value="registry" />
          <span>Registry install</span>
          <small>{items.filter((item) => item.distribution === "registry").length}</small>
        </label>
      </fieldset>

      <fieldset>
        <legend>Category</legend>
        {categories.map((category) => (
          <label class="check-row">
            <input data-category type="checkbox" value={category} />
            <span>{category}</span>
            <small>{countBy("category", category)}</small>
          </label>
        ))}
      </fieldset>

      <fieldset>
        <legend>Publisher</legend>
        {publishers.map((publisher) => (
          <label class="check-row">
            <input data-publisher type="checkbox" value={publisher} />
            <span>{publisher}</span>
            <small>{countBy("publisher", publisher)}</small>
          </label>
        ))}
      </fieldset>

      <fieldset>
        <legend>License</legend>
        {licenses.map((license) => (
          <label class="check-row">
            <input data-license type="checkbox" value={license} />
            <span>{license}</span>
            <small>{countBy("license", license)}</small>
          </label>
        ))}
      </fieldset>
    </aside>

    <div class="package-results" aria-label="Armory package catalog">
      {items.map((item) => (
        <article
          class="package-card"
          data-row
          data-kind={item.kind}
          data-category={item.category}
          data-publisher={item.publisher}
          data-license={item.license ?? ""}
          data-distribution={item.distribution}
          data-search={`${item.name} ${item.id} ${item.kind} ${item.category} ${item.publisher} ${item.description} ${item.ociRef ?? ""} ${item.capabilities.join(" ")}`}
        >
          <div class="package-card-main">
            <div class="package-title-row">
              <a href={`/packages/${item.kind}/${item.id}`} class="package-title">{item.name}</a>
              <span class="badge">{item.kind}</span>
              <span class={`badge ${item.distribution === "oci" ? "badge-oci" : "badge-registry"}`}>
                {item.distribution === "oci" ? "OCI artifact" : "Registry install"}
              </span>
              {item.official && <span class="badge badge-verified">Official</span>}
            </div>
            <p>{item.description}</p>
            <div class="package-meta-line">
              <span>{item.publisher}</span>
              <span>{item.category}</span>
              <span>{item.version}</span>
              {item.license && <span>{item.license}</span>}
            </div>
            {item.capabilities.length > 0 && (
              <div class="chip-row">
                {item.capabilities.slice(0, 7).map((capability) => <span>{capability}</span>)}
              </div>
            )}
          </div>
          <div class="package-card-side">
            <code>{item.installCommand}</code>
            <small class="install-note">{item.installNote}</small>
            <div class="link-row">
              <a href={`/packages/${item.kind}/${item.id}`}>Details</a>
              <a href={item.sourceUrl}>Source</a>
              {hasDistinctRepository(item) && <a href={item.repositoryUrl}>Repository</a>}
              <a href={item.armoryUrl}>Armory metadata</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
  <p class="empty-state" data-empty hidden>No packages match the current filters.</p>
</section>

<script>
    const root = document.querySelector("[data-catalog]");
    if (root) {
    const search = root.querySelector("[data-search]");
    const kindInputs = Array.from(root.querySelectorAll("[data-kind]"));
    const categoryInputs = Array.from(root.querySelectorAll("[data-category]"));
    const distributionInputs = Array.from(root.querySelectorAll("[data-distribution]"));
    const publisherInputs = Array.from(root.querySelectorAll("[data-publisher]"));
    const licenseInputs = Array.from(root.querySelectorAll("[data-license]"));
    const rows = Array.from(root.querySelectorAll("[data-row]"));
    const count = root.querySelector("[data-count]");
    const empty = root.querySelector("[data-empty]");

    const selected = (inputs) => inputs.filter((input) => input.checked).map((input) => input.value);
    const anyMatches = (values, actual) => values.length === 0 || values.includes(actual);

    const apply = () => {
      const q = search.value.trim().toLowerCase();
      const selectedKindsRaw = selected(kindInputs);
      const selectedKinds = selectedKindsRaw.includes("all") ? [] : selectedKindsRaw;
      const selectedCategories = selected(categoryInputs);
      const selectedDistributions = selected(distributionInputs);
      const selectedPublishers = selected(publisherInputs);
      const selectedLicenses = selected(licenseInputs);
      let visible = 0;

      for (const row of rows) {
        const matchesSearch = !q || row.dataset.search.toLowerCase().includes(q);
        const matchesKind = anyMatches(selectedKinds, row.dataset.kind);
        const matchesCategory = anyMatches(selectedCategories, row.dataset.category);
        const matchesDistribution = anyMatches(selectedDistributions, row.dataset.distribution);
        const matchesPublisher = anyMatches(selectedPublishers, row.dataset.publisher);
        const matchesLicense = anyMatches(selectedLicenses, row.dataset.license);
        const show = matchesSearch && matchesKind && matchesCategory && matchesDistribution && matchesPublisher && matchesLicense;
        row.hidden = !show;
        if (show) visible += 1;
      }

      count.textContent = `${visible} package${visible === 1 ? "" : "s"}`;
      empty.hidden = visible !== 0;
    };

    search.addEventListener("input", apply);
    for (const input of [...kindInputs, ...categoryInputs, ...distributionInputs, ...publisherInputs, ...licenseInputs]) {
      input.addEventListener("change", () => {
        if (input.dataset.kind !== undefined && input.value === "all" && input.checked) {
          for (const other of kindInputs) {
            if (other !== input) other.checked = false;
          }
        } else if (input.dataset.kind !== undefined && input.checked) {
          const all = kindInputs.find((candidate) => candidate.value === "all");
          if (all) all.checked = false;
        }
        apply();
      });
    }
    apply();
  }
</script>
