---
import BaseLayout from "../layouts/BaseLayout.astro";
import data from "../data/armory.json";
import type { ArmoryData, ArmoryItem } from "../types";

const catalog = data as ArmoryData;
const items = catalog.items as ArmoryItem[];
const generatedAt = new Date(catalog.generatedAt).toLocaleString("en-US", {
  dateStyle: "medium",
  timeStyle: "short",
  timeZone: "UTC"
});
const stats = {
  extensions: items.filter((item) => item.kind === "extension").length,
  skills: items.filter((item) => item.kind === "skill").length,
  personas: items.filter((item) => item.kind === "persona").length,
  tones: items.filter((item) => item.kind === "tone").length,
  agents: items.filter((item) => item.kind === "agent").length,
  profiles: items.filter((item) => item.kind === "profile").length,
  oci: items.filter((item) => item.distribution === "oci").length,
  registry: items.filter((item) => item.distribution === "registry").length,
  promptCompatible: items.filter((item) => item.compatibility.tier === 1).length,
  manifestCompatible: items.filter((item) => item.compatibility.tier === 2).length,
};
const surfaces = [
  { label: "Skills", href: "/skills", count: stats.skills, note: "Instruction packs" },
  { label: "Personas", href: "/personas", count: stats.personas, note: "Role prompts" },
  { label: "Tones", href: "/tones", count: stats.tones, note: "Style adapters" },
  { label: "Profiles", href: "/profiles", count: stats.profiles, note: "Dependency manifests" },
  { label: "Agents", href: "/agents", count: stats.agents, note: "Catalog blueprints" },
  { label: "Extensions", href: "/extensions", count: stats.extensions, note: "Native tool packages" },
];
---

<BaseLayout>
  <section class="artifact-hero">
    <div>
      <p class="eyebrow">Omegon Armory</p>
      <h1>Reviewed agent ecosystem artifacts.</h1>
      <p>
        A clinical index of signed OCI payloads and registry-resolved extensions for Omegon.
        Packages declare native behavior, degraded compatibility, provenance, and public-payload
        safety posture.
      </p>
    </div>
    <dl class="artifact-summary" aria-label="Registry summary">
      <div><dt>Total entries</dt><dd>{items.length}</dd></div>
      <div><dt>OCI artifacts</dt><dd>{stats.oci}</dd></div>
      <div><dt>Registry installs</dt><dd>{stats.registry}</dd></div>
      <div><dt>Generated</dt><dd>{generatedAt}</dd></div>
    </dl>
  </section>

  <section class="artifact-hub" aria-label="Artifact hub">
    <div class="hub-panel primary">
      <p class="eyebrow">Browse</p>
      <h2>Artifact surfaces</h2>
      <div class="surface-list">
        {surfaces.map((surface) => (
          <a href={surface.href} class="surface-row">
            <span>
              <strong>{surface.label}</strong>
              <small>{surface.note}</small>
            </span>
            <code>{surface.count}</code>
          </a>
        ))}
      </div>
    </div>

    <div class="hub-panel">
      <p class="eyebrow">Distribution</p>
      <h2>Registry endpoints</h2>
      <dl class="endpoint-list">
        <div><dt>Catalog API</dt><dd><a href="/api/index.json">/api/index.json</a></dd></div>
        <div><dt>OCI namespace</dt><dd><code>{catalog.registry || "ghcr.io/styrene-lab/omegon-armory"}</code></dd></div>
        <div><dt>Operations</dt><dd><a href="/docs/armory-operations">Publishing runbook</a></dd></div>
        <div><dt>Compatibility</dt><dd><a href="/docs/compatibility">Degradation model</a></dd></div>
      </dl>
    </div>

    <div class="hub-panel">
      <p class="eyebrow">Compatibility</p>
      <h2>Portable use</h2>
      <dl class="endpoint-list">
        <div><dt>Prompt-compatible</dt><dd>{stats.promptCompatible}</dd></div>
        <div><dt>Manifest-compatible</dt><dd>{stats.manifestCompatible}</dd></div>
        <div><dt>Public payload lint</dt><dd><a href="/docs/public-payload-security">Security posture</a></dd></div>
      </dl>
    </div>
  </section>
</BaseLayout>
