---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CommandBlock from "../../../components/CommandBlock.astro";
import data from "../../../data/armory.json";
import type { ArmoryItem } from "../../../types";

export function getStaticPaths() {
  const items = data.items as ArmoryItem[];
  return items.map((item) => ({
    params: { kind: item.kind, id: item.id },
    props: { item }
  }));
}

const { item } = Astro.props as { item: ArmoryItem };
const hasDistinctRepository = item.repositoryUrl && item.repositoryUrl !== item.sourceUrl;
const hasDistinctHomepage =
  item.homepageUrl &&
  item.homepageUrl !== item.sourceUrl &&
  item.homepageUrl !== item.repositoryUrl;
---

<BaseLayout title={`${item.name} | Omegon Armory`} description={item.description}>
  <article class="detail-layout">
    <header class="detail-header">
      <div>
        <p class="eyebrow">{item.kind} / {item.category}</p>
        <h1>{item.name}</h1>
        <p>{item.description}</p>
        <div class="detail-actions">
          <a href={item.sourceUrl}>Source</a>
          {hasDistinctRepository && <a href={item.repositoryUrl}>Repository</a>}
          <a href={item.armoryUrl}>Armory metadata</a>
          {hasDistinctHomepage && <a href={item.homepageUrl}>Homepage</a>}
        </div>
      </div>
      <dl class="metadata-panel">
        <div><dt>Version</dt><dd>{item.version}</dd></div>
        <div><dt>Kind</dt><dd>{item.kind}</dd></div>
        <div><dt>Distribution</dt><dd>{item.distribution === "oci" ? "OCI artifact" : "Extension registry"}</dd></div>
        <div><dt>Publisher</dt><dd>{item.publisher}</dd></div>
        {item.official && <div><dt>Status</dt><dd>Official</dd></div>}
        {item.license && <div><dt>License</dt><dd>{item.license}</dd></div>}
        {item.minOmegon && <div><dt>Min Omegon</dt><dd>{item.minOmegon}</dd></div>}
      </dl>
    </header>

    <section class="detail-grid">
      <div class="detail-main">
        <h2>Install</h2>
        <CommandBlock label="Omegon" command={item.installCommand} />
        <p class="install-note large">{item.installNote}</p>
        {item.distribution === "registry" && (
          <p class="distribution-note">
            This extension is resolved by the Omegon extension registry and installed from its upstream repository/release metadata.
          </p>
        )}
        {item.ociRef && <CommandBlock label="OCI pull" command={`oras pull ${item.ociRef}`} />}
        {item.verifyCommand && <CommandBlock label="Verify signature" command={item.verifyCommand} />}

        {item.capabilities.length > 0 && (
          <>
            <h2>Capabilities</h2>
            <div class="chip-row large">
              {item.capabilities.map((capability) => <span>{capability}</span>)}
            </div>
          </>
        )}

        <h2>Compatibility</h2>
        <div class="dependency-list">
          {item.compatibility.native.map((mode) => (
            <div class="dependency-card">
              <div>
                <strong>Native: {mode.runtime}</strong>
                <span>{mode.mode}</span>
              </div>
              {mode.installCommand && <code>{mode.installCommand}</code>}
            </div>
          ))}
          {item.compatibility.degraded.map((mode) => (
            <div class="dependency-card">
              <div>
                <strong>Degraded: {mode.runtime}</strong>
                <span>{mode.mode}</span>
              </div>
              {mode.entrypoints && mode.entrypoints.length > 0 && <code>{mode.entrypoints.join(", ")}</code>}
            </div>
          ))}
        </div>
        {item.compatibility.notes.length > 0 && (
          <ul class="file-list">
            {item.compatibility.notes.map((note) => <li>{note}</li>)}
          </ul>
        )}

        {item.interfaces && (
          <>
            <h2>Extension Interfaces</h2>
            <div class="dependency-list">
              {Object.entries(item.interfaces).map(([name, details]) => (
                <div class="dependency-card">
                  <div>
                    <strong>{name}</strong>
                    <span>{String(details.status)}</span>
                  </div>
                  {details.install && <code>{String(details.install)}</code>}
                  {details.binary && <code>{String(details.binary)}</code>}
                  {Array.isArray(details.commands) && details.commands.length > 0 && <code>{details.commands.join(", ")}</code>}
                  {Array.isArray(details.tools) && details.tools.length > 0 && <code>{details.tools.join(", ")}</code>}
                </div>
              ))}
            </div>
          </>
        )}

        {item.dependencies.length > 0 && (
          <>
            <h2>Dependencies</h2>
            <div class="dependency-list">
              {item.dependencies.map((dependency) => (
                <div class="dependency-card">
                  <div>
                    <strong>{dependency.id}</strong>
                    <span>
                      {dependency.kind}{dependency.version ? ` ${dependency.version}` : ""}
                      {dependency.compatibility ? ` · tier ${dependency.compatibility.tier} · ${dependency.compatibility.mode}` : ""}
                    </span>
                  </div>
                  {dependency.enabled === false && <span class="badge badge-warning">not enabled</span>}
                  {dependency.compatibility?.nativeOnly && <span class="badge badge-warning">native only</span>}
                  {dependency.installCommand && <code>{dependency.installCommand}</code>}
                </div>
              ))}
            </div>
          </>
        )}

        <h2>Included Files</h2>
        <ul class="file-list">
          {item.files.map((file) => <li><code>{file}</code></li>)}
        </ul>
      </div>

      <aside class="detail-side">
        <h2>Package Metadata</h2>
        <dl>
          <div><dt>Source</dt><dd><a href={item.sourceUrl}>{item.sourceUrl}</a></dd></div>
          {hasDistinctRepository && <div><dt>Repository</dt><dd><a href={item.repositoryUrl}>{item.repositoryUrl}</a></dd></div>}
          <div><dt>Armory Metadata</dt><dd><a href={item.armoryUrl}>{item.sourcePath}</a></dd></div>
          <div><dt>Distribution</dt><dd>{item.distribution === "oci" ? "OCI artifact" : "Extension registry"}</dd></div>
          <div><dt>Compatibility Tier</dt><dd>{item.compatibility.tier}</dd></div>
          {item.manifestId && <div><dt>Manifest ID</dt><dd><code>{item.manifestId}</code></dd></div>}
          {item.ociRef && <div><dt>OCI Ref</dt><dd><code>{item.ociRef}</code></dd></div>}
          {item.artifactType && <div><dt>Artifact Type</dt><dd><code>{item.artifactType}</code></dd></div>}
          {item.payloadDigest && <div><dt>Payload Digest</dt><dd><code>{item.payloadDigest}</code></dd></div>}
        </dl>
      </aside>
    </section>
  </article>
</BaseLayout>
